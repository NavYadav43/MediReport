# MediReport Environment Configuration
# Copy this file to .env and fill in your values

# REQUIRED: Get your Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Django settings (change SECRET_KEY in production!)
DJANGO_SECRET_KEY=your-super-secret-key-change-in-production
DJANGO_DEBUG=True
